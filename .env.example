# =============================================================
# norm-changes 環境変数設定
# .env.example をコピーして .env を作成してください。
# .env は git に含めないこと（.gitignore 済み）。
# =============================================================

# === 必須 ===

# Supabase の Transaction mode プーラー接続文字列（port 6543）
# Vercel / ローカル共通。ダッシュボードの "Connect" → "Transaction" でコピー。
DATABASE_URL=""

# Supabase の Session mode プーラー接続文字列（port 5432）
# prisma migrate deploy 専用（Transaction mode では migrate が動かない）。
# ダッシュボードの "Connect" → "Session" でコピー。ユーザー名は postgres.[PROJECT_REF] 形式。
DIRECT_DATABASE_URL=""

# Vercel Cron 認証トークン。任意の文字列を設定し、Vercel の Environment Variables にも同じ値を登録する。
# ローカルで cron エンドポイントを試す場合: curl -H "Authorization: Bearer <値>" http://localhost:3000/api/ingest/cron
CRON_SECRET=""

# === 管理API認証（任意・推奨）===

# 管理系APIエンドポイントへのアクセスを制限するAPIキー。
# 設定すると POST /api/analyze, POST/DELETE /api/notification-filters, POST /api/slack-config 等が保護される。
# 任意の強力なランダム文字列を設定（例: openssl rand -hex 32）。
# 未設定時は管理系APIが認証なしで公開される（開発用途のみ推奨）。
# ADMIN_API_KEY=""

# === AI分析（任意）===

# OpenAI APIキー。設定すると法令変更のリスク判定・レポートをAIで生成する。
# 未設定時はAI分析不可（analyze APIが503を返す）。
# 取得: https://platform.openai.com/api-keys
# OPENAI_API_KEY=""

# === Slack通知（任意）===

# Slack Incoming Webhook URL。設定するとリスクありの法令変更をSlackに通知する。
# 未設定時は通知をスキップ（エラーにはならない）。
# 取得: Slack App → Incoming Webhooks
# SLACK_WEBHOOK_URL=""

# === デプロイ設定（任意）===

# 本番サイトのURL。Slack通知内の「詳細ページ」リンクに使われる。
# Vercel デプロイ時は VERCEL_URL が自動設定されるため不要。
# ローカルで refresh:ingest を実行するとき、通知リンクを本番URLにしたい場合に設定。
# SITE_URL="https://your-app.vercel.app"

# === Google Analytics（任意）===

# Google Analytics 4 の測定ID（G-XXXXXXXXXX 形式）。
# 未設定時はGAを読み込まない。
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
