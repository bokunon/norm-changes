# 接続文字列をそのまま設定（Issue #26）。値は空またはプレースホルダーのみ。.env は git に含めない。
DATABASE_URL=""
DIRECT_DATABASE_URL=""

# 例（Supabase の Connection string をコピーして貼る）:
# DATABASE_URL="postgresql://postgres.xxxx:****@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?schema=public"
# DIRECT_DATABASE_URL="postgresql://postgres.xxxx:****@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?schema=public"

# Slack 通知（任意）
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"

# Issue #14: Vercel Cron で /api/ingest/cron を呼ぶ際の認証用。本番では Vercel の Environment Variables に設定すること。
# ローカルで cron エンドポイントを試す場合のみ .env に書く（任意）。
# CRON_SECRET=""
