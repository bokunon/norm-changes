# データベース接続（必須）
# Supabase / Neon 等の PostgreSQL の接続文字列
# Direct connection の URI を推奨
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Slack 通知（任意）
# 設定時、新規 NormChange 作成時に Incoming Webhook へ通知
# 未設定の場合は通知しない
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"
