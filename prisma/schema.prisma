// 法令インパクト管理システム - データモデル
// docs/architecture.md の ER 図に準拠

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // 接続 URL は prisma.config.ts で指定
}

// 法令・ガイドライン等の一次情報（法律・政令・省令・ガイドライン等）
model NormSource {
  id          String   @id @default(cuid())
  externalId  String?  @unique // e-Gov 法令API の LawId など（重複登録防止用）
  type        String   // LAW, ORDINANCE, REGULATION, GUIDELINE, NOTICE, OTHER
  title       String
  number      String?  // 法令番号など
  publisher   String?  // 所管省庁
  publishedAt DateTime
  effectiveAt DateTime?
  url         String?
  rawText     String?  @db.Text // 本文（改正後全文。Issue #24）
  rawTextPrev String?  @db.Text // 改正前全文（比較用。Issue #25）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  changes NormChange[]
}

// 実務上の「変更点」「対応が必要な論点」の単位
model NormChange {
  id               String    @id @default(cuid())
  normSourceId     String
  summary          String    @db.Text
  obligationLevel  String    // MUST, SHOULD, INFO
  penaltyRisk      String    // HIGH, MID, LOW, NONE（後方互換）
  penaltyDetail    String?   @db.Text
  // Issue #16/#19: 3軸リスク（生存・金銭・信用）
  riskSurvival     Boolean   @default(false) // 業務停止・免許取消等
  riskFinancial    Boolean   @default(false) // 罰金・課徴金等
  riskCredit       Boolean   @default(false) // 社名公表・勧告等
  effectiveFrom    DateTime?
  deadline         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  // Issue #12: AI 生成レポート（未設定時は null）
  reportSummary               String?   @db.Text // サマリ（箇条書きの要約）
  reportActionItems           Json?     // 箇条書きアクション一覧 string[]
  reportDetailedRecommendations Json?   // 詳細推奨アクション＋根拠 { action: string, basis: string }[]

  normSource   NormSource      @relation(fields: [normSourceId], references: [id], onDelete: Cascade)
  tags         NormChangeTag[]
}

// 業界・機能領域・データ種別などの汎用タグ
model Tag {
  id          String   @id @default(cuid())
  type        String   // INDUSTRY, BUSINESS_SIZE, FUNCTION, DATA_TYPE, RISK_LEVEL, OTHER
  key         String   @unique // 内部キー（例: finance, hr, personal_info）
  labelJa     String   // 表示名
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  normChanges NormChangeTag[]
}

// NormChange と Tag の多対多中間テーブル
model NormChangeTag {
  id            String   @id @default(cuid())
  normChangeId  String
  tagId         String
  createdAt     DateTime @default(now())

  normChange NormChange @relation(fields: [normChangeId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([normChangeId, tagId])
  @@index([normChangeId])
  @@index([tagId])
}

// 利用者（Web/Slack 通知の対象）
model User {
  id          String   @id @default(cuid())
  name        String?
  email       String?
  slackUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  filters UserFilter[]
}

// ユーザーごとの関心タグ条件（Web フィルタ・Slack 通知条件）
model UserFilter {
  id            String   @id @default(cuid())
  userId        String
  name          String   // フィルタ名（例: 自分用, 情シス担当用）
  includeTagIds String   @db.Text // JSON 配列（Tag.id のリスト）
  excludeTagIds String?  @db.Text // JSON 配列（任意）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Issue #30: Slack 通知用フィルタ（新規 NormChange がこの条件に一致したときのみ通知）
model NotificationFilter {
  id            String    @id @default(cuid())
  name          String    // フィルタ名（例: 生存リスクのみ, 金銭関連）
  publishedFrom DateTime? // 公示日 From（null は条件に含めない）
  publishedTo   DateTime? // 公示日 To（null は条件に含めない）
  riskSurvival  Boolean   @default(false) // 生存リスクに一致するものを通す
  riskFinancial Boolean   @default(false) // 金銭リスクに一致するものを通す
  riskCredit    Boolean   @default(false) // 信用リスクに一致するものを通す
  normType      String?   // 種別（LAW 等。null は条件に含めない）
  tagId         String?   // タグで絞る（null は条件に含めない）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
}
